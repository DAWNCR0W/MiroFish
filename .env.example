# LLM API 구성(OpenAI SDK 형식의 모든 LLM API 지원)
# 권장 예시: OpenAI API 또는 OpenAI 호환 게이트웨이
# 먼저 40라운드 미만의 시뮬레이션으로 시험해 보세요
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4.1-mini

# Flask/로그 설정(선택 사항)
FLASK_DEBUG=false
MIROFISH_LOG_LEVEL=INFO

# ===== ZEP 기억 그래프 구성 =====

# ===== LLM 가속 구성(선택 사항) =====
# `LLM_BOOST_ENABLED=true`일 때만 활성화됩니다.
# 활성화하지 않을 경우 비워 두어 자리표시자가 유효한 설정으로 잘못 인식되지 않게 하세요.
LLM_BOOST_ENABLED=false
LLM_BOOST_API_KEY=
LLM_BOOST_BASE_URL=
LLM_BOOST_MODEL_NAME=
